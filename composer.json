{
  "name": "strawberry-labs/berrycrawl",
  "description": "Berrycrawl PHP Library",
  "keywords": [
    "berrycrawl",
    "api",
    "sdk"
  ],
  "license": "Apache-2.0",
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "psr/http-client": "^1.0",
    "psr/http-client-implementation": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-factory-implementation": "^1.0",
    "psr/http-message": "^1.1 || ^2.0",
    "php-http/discovery": "^1.0",
    "php-http/multipart-stream-builder": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5.22",
    "friendsofphp/php-cs-fixer": "3.5.0",
    "phpstan/phpstan": "^1.12",
    "guzzlehttp/guzzle": "^7.4"
  },
  "autoload": {
    "psr-4": {
      "Berrycrawl\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Berrycrawl\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "build": [
      "@php -l src",
      "@php -l tests"
    ],
    "test": "phpunit",
    "analyze": "phpstan analyze src tests --memory-limit=1G"
  },
  "authors": [
    {
      "name": "Strawberry Labs LLC"
    }
  ],
  "homepage": "https://docs.berrycrawl.com",
  "support": {
    "source": "https://github.com/strawberry-labs/berrycrawl-php",
    "issues": "https://github.com/strawberry-labs/berrycrawl-php/issues"
  }
}
